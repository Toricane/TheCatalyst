# The Catalyst Environment Configuration
# Copy this file to .env and fill in your actual values

# CLOD API Key (primary — https://clod.io)
CLOD_API_KEY=

# Optional: override CLOD base URL (defaults to https://api.clod.io/v1)
# CLOD_API_BASE=https://api.clod.io/v1

# Google Gemini API Key (fallback only — https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Optional overrides (defaults are in backend/config.py)
MODEL_NAME=GPT OSS 120B
ALT_MODEL_NAME=gemini-2.5-flash
SHOW_THINKING=false
# CONTEXT_FORMAT=toon
# ENVELOPE_FORMAT=toon

# Supply a custom SQLAlchemy URL or leave blank for sqlite:///data/catalyst.db
DATABASE_URL=
